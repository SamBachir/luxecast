{
  "info": {
    "name": "LUXECAST Demo Pack API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth Register",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/auth/register",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "auth",
            "register"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\"full_name\": \"Jane Doe\", \"email\": \"jane@example.com\", \"password\": \"secret123\"}"
        }
      }
    },
    {
      "name": "Talent Search",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/api/talent/search?category=Editorial%20Model&city=Sydney",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "talent",
            "search"
          ],
          "query": [
            {
              "key": "category",
              "value": "Editorial Model"
            },
            {
              "key": "city",
              "value": "Sydney"
            }
          ]
        }
      }
    },
    {
      "name": "Create Booking",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/bookings",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "bookings"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\"talent_id\": 2, \"booking_type\": \"DIRECT\", \"start_time\": \"2026-05-01T14:00:00Z\", \"location\": \"Sydney CBD Studio\", \"gross_amount\": 2400}"
        }
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000"
    },
    {
      "key": "token",
      "value": ""
    }
  ]
}